        "main": "packages/libs/permissions/src/index.ts",
        "tsConfig": "packages/libs/permissions/tsconfig.lib.json"
      },
      "configurations": { "production": {} }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx jest --config=jest.config.js --passWithNoTests",
        "cwd": "packages/libs/permissions"
      }
    }
  },
  "tags": []
}
