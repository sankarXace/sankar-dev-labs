{
  "name": "database",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/libs/database/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/libs/database/dist",
        "main": "packages/libs/database/src/index.ts",
        "tsConfig": "packages/libs/database/tsconfig.lib.json"
      },
      "configurations": {
        "production": {}
      }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma migrate deploy",
        "cwd": "packages/libs/database"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma db seed",
        "cwd": "packages/libs/database"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx jest --config=jest.config.js --passWithNoTests",
        "cwd": "packages/libs/database"
      }
    }
  },
  "tags": []
}
