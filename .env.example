# Database (required for services using Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/saas_platform

# Redis (optional; used by issue-events, notification consumer, webhook delivery, realtime)
REDIS_URL=redis://localhost:6379

# JWT (required for auth-service and api-gateway)
JWT_SECRET=your-secret-at-least-16-characters

# HTTP ports (defaults shown)
PORT=3000
AUTH_HTTP_PORT=3001
WORKSPACE_HTTP_PORT=3011
ISSUE_HTTP_PORT=3021
NOTIFICATION_HTTP_PORT=3031
INTEGRATION_HTTP_PORT=3041

# TCP ports and hosts for inter-service communication (api-gateway only; defaults shown)
AUTH_SERVICE_HOST=localhost
AUTH_TCP_PORT=3002
WORKSPACE_SERVICE_HOST=localhost
WORKSPACE_TCP_PORT=3010
ISSUE_SERVICE_HOST=localhost
ISSUE_TCP_PORT=3020
INTEGRATION_SERVICE_HOST=localhost
INTEGRATION_TCP_PORT=3040

# Node
NODE_ENV=development
